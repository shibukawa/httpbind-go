{
  "routes": [
    {
      "method": "GET",
      "path": "/ping",
      "handler": {
        "form": "named",
        "name": "pingHandler"
      },
      "request": "PingRequest",
      "response": "PingResponse",
      "success_statuses": [
        200
      ],
      "wrappers": {
        "allow_query_semicolons": false,
        "timeout": "1s",
        "timeout_message": "slow"
      }
    }
  ]
}
