{
  "routes": [
    {
      "method": "POST",
      "path": "/upload",
      "handler": {
        "form": "named",
        "name": "uploadHandler"
      },
      "request": "UploadRequest",
      "response": "UploadResponse",
      "wrappers": {
        "allow_query_semicolons": false,
        "max_request_body_bytes": 10485760,
        "timeout": "30s",
        "timeout_message": "timeout"
      }
    }
  ]
}
