{
  "routes": [
    {
      "method": "POST",
      "path": "/jobs",
      "handler": {
        "form": "named",
        "name": "jobHandler"
      },
      "request": "JobRequest",
      "response": "JobResponse",
      "success_statuses": [
        200
      ],
      "wrappers": {
        "allow_query_semicolons": false,
        "timeout": "30s",
        "timeout_message": "timeout"
      }
    }
  ]
}
