{
  "routes": [
    {
      "method": "GET",
      "path": "/items",
      "handler": {
        "form": "named",
        "name": "listHandler"
      },
      "request": "ListRequest",
      "response": "ListResponse",
      "success_statuses": [
        200
      ],
      "wrappers": {
        "allow_query_semicolons": false
      }
    },
    {
      "method": "POST",
      "path": "/items",
      "handler": {
        "form": "named",
        "name": "createHandler"
      },
      "request": "CreateRequest",
      "response": "CreateResponse",
      "errors": [
        "BadRequest"
      ],
      "success_statuses": [
        200
      ],
      "wrappers": {
        "allow_query_semicolons": false
      }
    }
  ]
}
